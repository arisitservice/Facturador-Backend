{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar API",
      "type": "shell",
      "command": "dotnet watch --project Biller.Presentation.Api/Biller.Presentation.Api.csproj",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "dotnet watch",
          "endsPattern": "Now listening on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "API"
      }
    }
  ]
}
